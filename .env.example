# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/rekollect

# Neo4j
NEO4J_URI=bolt://127.0.0.1:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=rekollect-dev
NEO4J_DATABASE=neo4j

# OpenAI (required for embeddings + graph extraction)
OPENAI_API_KEY=sk-...

# Server
PORT=8181

# Embeddings
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_DIM=1536

# Graph embeddings
GRAPH_EMBEDDING_MODEL=text-embedding-3-small
GRAPH_EMBEDDING_DIM=1536

# Extraction
LLM_MODEL=gpt-4.1-nano
DEDUP_MODEL=gpt-4.1
